{
  "manifest_version": 3,
  "name": "Etsy Listing",
  "version": "2.0.0",
  "description": "AI-powered Etsy listing creator - analyze images, generate content & mockups, fill forms automatically",
  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.etsy.com/*",
    "https://etsy.com/*",
    "https://*.etsystatic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.etsy.com/*",
        "https://etsy.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
